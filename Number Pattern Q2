let n = 5;

for (let i = 0; i < n; i++) {

    let row = "";

    for (let s = 0; s < i; s++) {
        row += " ";
    }

    row += "1";

    let mid = n - i - 1;

    if (mid > 0) {

        if (i === 0) {
            row += " 4 6 4";
        } 
        else if (i === 1) {
            row += " 3 3";
        } 
        else if (i === 2) {
            row += " 2";
        } 
        else if (i === 2) {
            row += " 1";
        }

        row += " 1";
    }

    console.log(row);
}
