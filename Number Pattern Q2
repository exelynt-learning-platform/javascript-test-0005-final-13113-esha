let n = 4;
let size = 2 * n - 1;

for (let i = 0; i < size; i++) {
    let rowOutput = "";

    for (let j = 0; j < size; j++) {

        let top = i;
        let bottom = size - 1 - i;
        let left = j;
        let right = size - 1 - j;

        let minDistance = Math.min(top, bottom, left, right);

        rowOutput += (n - minDistance) + " ";
    }

    console.log(rowOutput.trim());
}
