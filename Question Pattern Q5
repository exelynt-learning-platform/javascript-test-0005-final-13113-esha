let rows = 10;

for (let i = 1; i <= rows; i++) {

    if (i == 1 || i == rows) {
        console.log("*");
    }
    else if (i == 2 || i == rows - 1) {
        console.log("* *".replace(" ", "")); // prints **
    }
    else if (i == 3 || i == rows - 2) {
        console.log("* *");
    }
    else {
        console.log("*   *");
    }

}
